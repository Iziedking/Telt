# Frontend public config. Copy to .env.local and fill in. NEXT_PUBLIC_ vars are exposed to
# the browser, so keep secrets out of here.

# Backend API base. Defaults to http://localhost:8787 in dev.
NEXT_PUBLIC_API_BASE=http://localhost:8787

# Where the landing background videos are hosted. The videos are large, so host them on a
# CDN (Vercel Blob, Cloudinary, an S3/R2 bucket) rather than committing them. Two options:
#  - Fixed-path host (bucket/Cloudinary): set the base URL here; the reel resolves each clip
#    to ${NEXT_PUBLIC_VIDEO_CDN}/poker.mp4, /chess.mp4, /prediction.mp4.
NEXT_PUBLIC_VIDEO_CDN=
#  - Hashed-filename host (e.g. Vercel Blob): list the full URLs in play order instead.
# NEXT_PUBLIC_VIDEO_URLS=https://xxx.public.blob.vercel-storage.com/poker-abc.mp4,https://xxx.public.blob.vercel-storage.com/chess-def.mp4
# Leave both blank in dev to read local files from public/videos.
