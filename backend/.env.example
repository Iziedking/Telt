# Telt backend environment. Copy to .env and fill in. Secrets stay here, never in code.

SUI_NETWORK=testnet
SUI_PRIVATE_KEY=                 # coordinator / treasury key (suiprivkey1...)
# Pin one fullnode. The default public endpoint is load-balanced across nodes that
# lag each other, which races gas-coin versions when several txs fire quickly.
AVOW_SUI_RPC=https://fullnode.testnet.sui.io:443

# From `sui client publish` of move/ (recorded in move/deployments/testnet.json)
ARENA_PACKAGE_ID=0xca171662f5f5cc4547bec5d96dc21173627880e148ac4686f77423e08dd9e395
ARENA_COORDINATOR_CAP=0x574dc3ebb8b0828e49efbfa2a55c510c785614e997a1cbb94f44d4e6d771d7b9
ARENA_TREASURY_OBJECT=0x4583f5d58cdf47cb54e95313054f24d1afc060046e9090c5a778e8c5c81a703c
# TreasuryCap<TEST_USDC>, held by the coordinator. tUSDC is the in-app currency users
# hold to fund contests and challenge duels (not the upgrade currency; upgrades use SUI).
ARENA_TESTUSDC_CAP=0xd2f708b02c60ddc0a7272add8085544011c9c90f5612d04ff9066a8adf151917
ARENA_TREASURY=0xc11c77d7f5f0555041e04a89a266edbe305da731c4f10c102bc4384536bbb65b
STAKE_ASSET=SUI                  # SUI for buy-ins and fees, no token dependency

# Avow is already live on testnet. Do not redeploy; point at this package id.
AVOW_PACKAGE_ID=0x4f3e25d7858a70ce4f1a437a3f91f24700407f52c68bb93775522d752841a3ee

# A tier's strength is its model. The lower tiers run on cheaper OpenRouter models;
# only tier 4 uses Anthropic Claude Haiku. Each tier is overridable below.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENROUTER_API_KEY=
LLM_MODEL=google/gemini-2.5-flash
# Per-tier model ladder (cheap -> strong). Defaults shown; tier 4 stays on Haiku.
TIER0_MODEL=meta-llama/llama-3.2-1b-instruct
TIER1_MODEL=meta-llama/llama-3.2-3b-instruct
TIER2_MODEL=meta-llama/llama-3.1-8b-instruct
TIER3_MODEL=openai/gpt-4o-mini
TIER4_MODEL=claude-haiku-4-5

# MemWal (memory.walrus.xyz). Optional: without these, memory is a no-op and
# intel is passed in-context for the demo. MemWal also needs a local Seal sidecar
# (default http://localhost:9000); memory stays off until MEMORY_ENABLED=on.
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMORY_ENABLED=off

# Autopilot: when on, the platform runs contests on a schedule to keep the arena busy.
AUTOPILOT_ENABLED=off
AUTOPILOT_INTERVAL_MS=3600000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/telt
PORT=8787
