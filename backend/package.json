{
  "name": "telt-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telt coordinator, poker runner, intel marketplace, and read API. Agents reason on Claude Haiku; every move is anchored through Avow.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "reason:check": "tsx src/scripts/reasonCheck.ts",
    "engine:test": "tsx src/poker/engine.test.ts",
    "setup:agents": "tsx src/coordinator/setupAgents.ts",
    "seed": "tsx src/coordinator/seedHistory.ts",
    "match": "tsx src/scripts/runMatch.ts",
    "intel": "tsx src/scripts/runIntel.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "typecheck": "tsc --noEmit",
    "records": "tsx src/scripts/records.ts",
    "tiertest": "tsx src/scripts/tierTest.ts",
    "benchmark": "tsx src/scripts/benchmark.ts",
    "modelcheck": "tsx src/scripts/modelCheck.ts",
    "solver": "tsx src/scripts/runSolver.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.106.0",
    "@hono/node-server": "^1.13.7",
    "@mysten/seal": "1.1.3",
    "@mysten/sui": "2.17.0",
    "@mysten/walrus": "1.1.7",
    "avow-sdk": "0.3.1",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "pg": "^8.13.1",
    "pokersolver": "2.1.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
